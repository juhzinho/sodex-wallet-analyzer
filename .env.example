# SoDEX Wallet Analyzer — environment variables
#
# This app calls the public SoDEX gateway from the server side (Next.js API
# routes) so no authentication keys are required at this time.
#
# If the gateway ever adds auth, add the key here and reference it in
# services/sodex/api.ts via process.env.SODEX_API_KEY.

# Optional: override the default SoDEX gateway base URLs
# SODEX_PERPS_BASE=https://mainnet-gw.sodex.dev/api/v1/perps
# SODEX_SPOT_BASE=https://mainnet-gw.sodex.dev/api/v1/spot
